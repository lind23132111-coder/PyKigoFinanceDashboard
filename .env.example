# ================================================
# PyKigoFinanceDashboard - Environment Variables Template
# ================================================
# Copy this file to .env.local and fill in your actual values.
# .env.local is in .gitignore and will NEVER be committed.
# ================================================

# ── Supabase ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase Schema (dev/public for sandbox support) ─
NEXT_PUBLIC_DB_SCHEMA=public

# ── Demo Mode ────────────────────────────────
# Set to 'true' to enable demo mode (no real DB required)
NEXT_PUBLIC_DEMO_MODE=false

# ── Gemini AI ─────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Site Password ─────────────────────────────
SITE_PASSWORD=your-secure-site-password-here
